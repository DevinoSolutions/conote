{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@conote/ai-core": ["../packages/conote-ai-core/src/index.ts"],
      "@conote/extension-ai": ["../packages/conote-extension-ai/src/index.ts"],
      "@conote/extension-ai-suggestion": ["../packages/conote-extension-ai-suggestion/src/index.ts"],
      "@conote/extension-ai-changes": ["../packages/conote-extension-ai-changes/src/index.ts"],
      "@conote/extension-ai-agent": ["../packages/conote-extension-ai-agent/src/index.ts"],
      "@tiptap/core": ["./node_modules/@tiptap/core/dist/index.d.ts"],
      "@tiptap/pm/*": ["./node_modules/@tiptap/pm/dist/*/index.d.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
